# Google OAuth client ID (required for Sign in with Google).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# gRPC-Web backend base URL. When using Envoy locally, use http://localhost:8080.
# When SPA and API are same origin (e.g. Envoy serves both), leave unset to use relative URLs.
NEXT_PUBLIC_GRPC_WEB_BASE=http://localhost:8080
