# Dev image: Node + buf CLI + deps, run next dev with TS codegen. Repo root is mounted at /app at run time.
# Run as host UID/GID so .next and node_modules keep correct permissions.
FROM node:25-alpine
RUN apk add --no-cache libc6-compat curl
# Install buf CLI for protobuf TS codegen (buf generate --template buf.gen.ts.yaml).
RUN curl -sSL "https://github.com/bufbuild/buf/releases/download/v1.66.0/buf-Linux-$(uname -m)" -o /usr/local/bin/buf && chmod +x /usr/local/bin/buf
WORKDIR /app
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
CMD ["npm", "run", "dev"]
